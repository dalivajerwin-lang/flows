# Flow environment variables — copy to .env.local and fill in.
# .env.local is gitignored (via *.local); never commit real values.

# --- App (required; used in src/lib/supabase.ts) ---
# Supabase project ivcnhqteahhwiphtdebr → Dashboard > Settings > API.
# VITE_* vars are embedded in the client bundle at build time — the anon key
# is public by design (RLS is the security boundary); never put the service
# role key in a VITE_ var.
VITE_SUPABASE_URL=https://ivcnhqteahhwiphtdebr.supabase.co
VITE_SUPABASE_ANON_KEY=

# --- a11y audit only (optional; scripts/a11y-audit.mjs) ---
# Credentials for existing test accounts, one per role. The audit skips any
# role whose vars are unset. Use throwaway accounts, not real user logins.
#A11Y_BASE=http://localhost:8080
#A11Y_CONSULTANT_EMAIL=
#A11Y_CONSULTANT_PASSWORD=
#A11Y_MANAGER_EMAIL=
#A11Y_MANAGER_PASSWORD=

# Edge functions (supabase/functions/*) need no entries here: SUPABASE_URL,
# SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are injected automatically
# by the Supabase runtime on deploy.
